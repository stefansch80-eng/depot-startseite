.card-label {
  color: var(--muted);
  font-size: 0.9rem;
  margin-bottom: 8px;
}

.health-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-top: 22px;
}

.health-ring {
  width: 92px;
  height: 92px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  background:
    radial-gradient(circle at center, rgba(7, 17, 29, 0.95) 52%, transparent 53%),
    conic-gradient(var(--accent) 0deg, rgba(255, 255, 255, 0.14) 0deg);
  border: 1px solid rgba(126, 240, 207, 0.22);
  color: var(--text);
  font-size: 1.3rem;
  font-weight: 700;
}

.signal-list,
.stack {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: 12px;
}

.signal-item,
.alert-card,
.mini-card,
.reason-card,
.future-card,
.position-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px;
}

.signal-item,
.alert-card,
.mini-card,
.reason-card,
.future-card {
  padding: 14px 16px;
}

.signal-item strong,
.alert-card strong,
.position-card strong,
.future-card strong {
  display: block;
  margin-bottom: 4px;
}

.tab-bar {
  position: sticky;
  top: 12px;
  display: flex;
  gap: 10px;
  padding: 10px;
  margin-bottom: 18px;
  background: rgba(10, 18, 31, 0.74);
  backdrop-filter: blur(16px);
  border: 1px solid var(--line);
  border-radius: 999px;
}

.tab-button {
  flex: 1;
}

.tab-button.is-active {
  background: linear-gradient(135deg, rgba(126, 240, 207, 0.24), rgba(126, 240, 207, 0.08));
  border-color: rgba(126, 240, 207, 0.36);
}

.tab-panel {
  display: none;
}

.tab-panel.is-active {
  display: block;
}

.card-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  margin-bottom: 18px;
}

.section-head-wrap {
  align-items: flex-start;
  flex-wrap: wrap;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0.45rem 0.72rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.06);
  color: var(--muted);
  font-size: 0.86rem;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.badge-accent {
  background: rgba(126, 240, 207, 0.12);
  color: var(--accent);
  border-color: rgba(126, 240, 207, 0.2);
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.mini-card .value {
  font-size: 1.4rem;
  line-height: 1.05;
  margin-bottom: 4px;
}

.tone-good {
  color: var(--accent);
}

.tone-warn {
  color: var(--warn);
}

.tone-danger {
  color: var(--danger);
}

.alert-card {
  display: grid;
  gap: 8px;
}

.alert-topline,
.position-head,
.bar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.pill {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 0.34rem 0.7rem;
  font-size: 0.78rem;
  border: 1px solid transparent;
}

.pill-good {
  color: var(--accent);
  background: rgba(126, 240, 207, 0.1);
  border-color: rgba(126, 240, 207, 0.18);
}

.pill-warn {
  color: var(--warn);
  background: rgba(255, 178, 94, 0.12);
  border-color: rgba(255, 178, 94, 0.18);
}

.pill-danger {
  color: var(--danger);
  background: rgba(255, 123, 111, 0.12);
  border-color: rgba(255, 123, 111, 0.18);
}

.bar {
  height: 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.bar > span {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #7ef0cf, #49d8f5);
}

.bar.warn > span {
  background: linear-gradient(90deg, #ffcf73, #ff9a6a);
}

.bar.danger > span {
  background: linear-gradient(90deg, #ff8e7f, #ff6370);
}

.feature-grid {
  display: grid;
  gap: 12px;
}

.feature-card {
  padding: 14px 16px;
  border-radius: 20px;
  background: linear-gradient(180deg, rgba(126, 240, 207, 0.1), rgba(255, 255, 255, 0.03));
  border: 1px solid rgba(126, 240, 207, 0.12);
}

.controls {
  display: grid;
  gap: 10px;
  width: min(100%, 420px);
}

input[type="search"] {
  width: 100%;
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.04);
  color: var(--text);
  padding: 0.9rem 1rem;
}

input[type="search"]::placeholder {
  color: rgba(152, 172, 197, 0.78);
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.position-card {
  padding: 16px;
  display: grid;
  gap: 12px;
}

.position-meta,
.position-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.meta-chip {
  padding: 0.34rem 0.65rem;
  border-radius: 999px;
  font-size: 0.8rem;
  color: var(--muted);
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.assistant-card {
  min-height: 420px;
}

.assistant-copy {
  display: grid;
  gap: 14px;
}

.assistant-block {
  padding: 16px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.assistant-block ul {
  margin: 10px 0 0;
  padding-left: 18px;
  color: var(--muted);
}

.compact-stack {
  gap: 10px;
}

.compact-stack .mini-card {
  padding: 12px 14px;
}

.reveal {
  opacity: 0;
  transform: translateY(16px);
  animation: revealUp 620ms ease forwards;
}

.reveal:nth-child(2) {
  animation-delay: 100ms;
}

.reveal:nth-child(3) {
  animation-delay: 160ms;
}

.reveal:nth-child(4) {
  animation-delay: 220ms;
}

@keyframes revealUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 880px) {
  .hero-grid,
  .card-grid {
    grid-template-columns: 1fr;
  }

  .tab-bar {
    bottom: 12px;
    top: auto;
    position: fixed;
    left: 12px;
    right: 12px;
  }

  .app-shell {
    padding-bottom: 116px;
  }
}

@media (max-width: 560px) {
  .app-shell {
    padding: 18px 14px 110px;
  }

  .hero-card,
  .panel-card {
    padding: 18px;
    border-radius: 24px;
  }

  .stat-grid {
    grid-template-columns: 1fr;
  }

  .health-row,
  .hero-topline,
  .alert-topline,
  .position-head,
  .section-head {
    align-items: flex-start;
    flex-direction: column;
  }

  .tab-bar {
    gap: 8px;
    padding: 8px;
  }

  .tab-button {
    padding-inline: 0.72rem;
  }
}

const CACHE_NAME = "depot-cockpit-v1";
const ASSETS = [
  "./",
  "./index.html",
  "./styles.css",
  "./app.js",
  "./manifest.webmanifest",
  "./assets/icon.svg",
  "./data/latest-snapshot.js",
];

self.addEventListener("install", (event) => {
  event.waitUntil(caches.open(CACHE_NAME).then((cache) => cache.addAll(ASSETS)));
});

self.addEventListener("activate", (event) => {
  event.waitUntil(
    caches.keys().then((keys) =>
      Promise.all(
        keys
          .filter((key) => key !== CACHE_NAME)
          .map((key) => caches.delete(key))
      )
    )
  );
});

self.addEventListener("fetch", (event) => {
  event.respondWith(
    caches.match(event.request).then((cached) => cached || fetch(event.request))
  );
});
